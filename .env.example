GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here

# For local development, SQLite is fine.
# For Railway with a mounted volume:
# DATABASE_URL=sqlite+aiosqlite:////data/cofs.db
# UPLOAD_DIR=/data/uploads

# For Supabase Postgres later:
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:6543/postgres

# Optional fallback provider selection.
# If omitted, the app prefers Gemini when GEMINI_API_KEY is present.
# LLM_PROVIDER=openai

# Optional OpenAI fallback.
# OPENAI_MODEL=gpt-4o
# OPENAI_API_KEY=your_openai_api_key_here
